model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-CA
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'source tables'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'production tables'

	annotation PBI_QueryGroupOrder = 1

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["source","people_data_source","people_employment_source","people_fact","department_dim","job_level_dim","term_dim","manager_dim","demographic_dim","education_dim","location_dim","marital_dim","_Measures","Date"]

annotation PBI_ProTooling = ["DevMode"]

ref table source
ref table people_fact
ref table department_dim
ref table job_level_dim
ref table term_dim
ref table manager_dim
ref table demographic_dim
ref table education_dim
ref table location_dim
ref table marital_dim
ref table _Measures
ref table Date
ref table Parameter

ref cultureInfo en-US

